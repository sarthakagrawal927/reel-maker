# ─── Story & image description generation ────────────────────────────────────
# Set one — if ANTHROPIC_API_KEY is present it takes priority over OpenAI
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ─── Image generation (choose one) ───────────────────────────────────────────

# Option A: fal.ai — Flux Pro, no setup, $0.03/image
# Get key: https://fal.ai/dashboard/keys
FAL_KEY=

# Option B: Modal — FLUX.1-schnell, $30 free credits, ~$0.002/image
# Setup: pip install modal && modal setup && modal deploy modal/image_gen.py
# Then paste the printed endpoint URL here:
MODAL_IMAGE_GEN_URL=

# ─── Text-to-speech ───────────────────────────────────────────────────────────
# ElevenLabs — free tier: 10k chars/month (~12 reels/month)
# Get key: https://elevenlabs.io
ELEVENLABS_API_KEY=
